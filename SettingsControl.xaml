<UserControl x:Class="MairaSimHub.SbtPlugin.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins"
             xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins"
             mc:Ignorable="d">

    <!-- DataContext is set to Plugin.Settings in code-behind.
         All Value / IsChecked bindings are TwoWay so slider/toggle changes
         write immediately back to the settings object. -->

    <ScrollViewer>
        <StackPanel>

            <!-- ================================================================
                 CONNECTION
                 ================================================================ -->
            <styles:SHSection Title="CONNECTION">
                <StackPanel>

                    <styles:SHToggleCheckbox IsChecked="{Binding SbtEnabled, Mode=TwoWay}">
                        Enable MAIRA SBT plugin
                    </styles:SHToggleCheckbox>

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding AutoConnect, Mode=TwoWay}">
                        Auto-connect to device on SimHub startup
                    </styles:SHToggleCheckbox>

                    <styles:SHSectionSeparator />

                    <StackPanel Orientation="Horizontal">
                        <styles:SHButtonPrimary Click="ConnectButton_Click"
                                                Margin="0,0,8,0">
                            Connect
                        </styles:SHButtonPrimary>
                        <styles:SHButtonSecondary Click="DisconnectButton_Click">
                            Disconnect
                        </styles:SHButtonSecondary>
                    </StackPanel>

                    <styles:SHSectionSeparator />

                    <TextBlock x:Name="ConnectionStatusText"
                               FontStyle="Italic"
                               Margin="0,0,0,4" />

                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 CALIBRATION ANGLES
                 ================================================================ -->
            <styles:SHSection Title="CALIBRATION ANGLES">
                <StackPanel>

                    <ui:TitledSlider Title="Minimum angle (°)"
                                     Minimum="0" Maximum="90"
                                     Value="{Binding MinimumAngle, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <ui:TitledSlider Title="Neutral angle (°)"
                                     Minimum="0" Maximum="180"
                                     Value="{Binding NeutralAngle, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <ui:TitledSlider Title="Maximum angle (°)"
                                     Minimum="90" Maximum="180"
                                     Value="{Binding MaximumAngle, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <!-- Sends NL / AL / BL commands to firmware with current angle values. -->
                    <styles:SHButtonPrimary HorizontalAlignment="Left"
                                            Click="ApplyCalibrationButton_Click">
                        Apply Calibration to Device
                    </styles:SHButtonPrimary>

                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 MOTOR SPEED
                 ================================================================ -->
            <styles:SHSection Title="MOTOR SPEED">
                <StackPanel>

                    <ui:TitledSlider Title="Max motor speed  (firmware velocity limiter, 5–50)"
                                     Minimum="5" Maximum="50"
                                     Value="{Binding MaxMotorSpeed, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <!-- Sends the ML command to firmware with the current max-speed value. -->
                    <styles:SHButtonPrimary HorizontalAlignment="Left"
                                            Click="ApplyMotorSpeedButton_Click">
                        Apply Motor Speed to Device
                    </styles:SHButtonPrimary>

                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 SURGE  (braking / acceleration)
                 ================================================================ -->
            <styles:SHSection Title="SURGE — BRAKING / ACCELERATION">
                <StackPanel>

                    <ui:TitledSlider Title="Surge max G  (G value that maps to ±1 normalised)"
                                     Minimum="0.1" Maximum="50"
                                     Value="{Binding SurgeMaxG, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding SurgeSubtractGravity, Mode=TwoWay}">
                        Subtract gravity component from longitudinal acceleration
                    </styles:SHToggleCheckbox>

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding SurgeInvert, Mode=TwoWay}">
                        Invert surge axis
                    </styles:SHToggleCheckbox>

                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 SWAY  (cornering)
                 ================================================================ -->
            <styles:SHSection Title="SWAY — CORNERING">
                <StackPanel>

                    <ui:TitledSlider Title="Sway max G  (G value that maps to ±1 normalised)"
                                     Minimum="0.1" Maximum="50"
                                     Value="{Binding SwayMaxG, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding SwaySubtractGravity, Mode=TwoWay}">
                        Subtract gravity component from lateral acceleration
                    </styles:SHToggleCheckbox>

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding SwayInvert, Mode=TwoWay}">
                        Invert sway axis
                    </styles:SHToggleCheckbox>

                </StackPanel>
            </styles:SHSection>

            <!-- ================================================================
                 HEAVE  (vertical / bumps)
                 ================================================================ -->
            <styles:SHSection Title="HEAVE — VERTICAL">
                <StackPanel>

                    <ui:TitledSlider Title="Heave max G  (G value that maps to ±1 normalised)"
                                     Minimum="0.1" Maximum="50"
                                     Value="{Binding HeaveMaxG, Mode=TwoWay}" />

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding HeaveSubtractGravity, Mode=TwoWay}">
                        Subtract gravity component from vertical acceleration  (default: ON)
                    </styles:SHToggleCheckbox>

                    <styles:SHSectionSeparator />

                    <styles:SHToggleCheckbox IsChecked="{Binding HeaveInvert, Mode=TwoWay}">
                        Invert heave axis
                    </styles:SHToggleCheckbox>

                </StackPanel>
            </styles:SHSection>

        </StackPanel>
    </ScrollViewer>
</UserControl>
